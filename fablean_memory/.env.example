# Server
PORT=4000

# PostgreSQL (choose either DATABASE_URL or individual PG* vars)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/fablean
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=fablean
PGSSL=false

# Auth
JWT_SECRET=dev_jwt_secret_change_me
JWT_EXPIRES_IN=7d

# External GPU service
GPU_API_URL=http://localhost:8000
